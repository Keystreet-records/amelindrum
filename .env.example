# === Практичный стек: Vercel + Supabase + Blob ===

# Supabase — тексты CMS + логин /admin
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Публичный URL сайта (OG, соцпревью). На Vercel — ваш домен.
VITE_SITE_URL=http://localhost:8080

# Vercel Blob — фото/видео из админки
# Vercel → Storage → Blob → Create (на проде токен подтянется сам)
# Локально: vercel env pull .env.local
BLOB_READ_WRITE_TOKEN=
