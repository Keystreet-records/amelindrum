# === Практичный стек: Vercel + Supabase + Cloudflare R2 ===

# Supabase — тексты CMS + логин /admin
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Публичный URL сайта (OG, соцпревью). На Vercel задайте https://ваш-домен.
# Локально можно оставить localhost — в проде localhost игнорируется.
VITE_SITE_URL=http://localhost:8080

# Cloudflare R2 — фото / видео / обложки из админки
# Dashboard → R2 → bucket + API token (Object Read & Write)
# Public access: custom domain (рекомендуется) или r2.dev URL
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=amelindrum-media
# Без trailing slash, например https://media.yourdomain.com или https://pub-xxxx.r2.dev
R2_PUBLIC_BASE_URL=
